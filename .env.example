# MemoX local environment example.
# Copy values into your shell environment before starting the backend.

# Required when auth.enabled=true.
MEMOX_ADMIN_PASSWORD=change-me-to-a-long-random-password

# Required by the default DashScope coordinator and embedding configuration.
DASHSCOPE_API_KEY=

# Optional providers. Fill only the providers you enable in config.yaml.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MINIMAX_API_KEY=
KIMI_API_KEY=
