# MemoX production environment template.
# Copy to .env on the production host, then replace every placeholder with a
# real secret from your password manager or secret store.
#
# Never commit a populated .env file.

# Required for auth.enabled=true. Use a long random password.
MEMOX_ADMIN_PASSWORD=replace-with-long-random-admin-password

# Optional but recommended for scheduled production monitoring. Use a long
# random token and configure GitHub Actions with the same value as
# MEMOX_PRODUCTION_MONITOR_TOKEN.
MEMOX_MONITOR_TOKEN=replace-with-long-random-monitor-token

# Required when local uploads are shared with external services through signed
# short-lived URLs.
MEMOX_FILE_SIGNING_SECRET=replace-with-long-random-file-signing-secret

# Required by the default production model/provider configuration and release
# gate checks.
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
QWEN_API_KEY=replace-with-qwen-api-key
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
MINIMAX_API_KEY=replace-with-minimax-api-key

# Optional model overrides. Keep qwen-plus unless your account has validated a
# different Qwen model in External E2E.
QWEN_MODEL=qwen-plus
I2V_TEST_MODEL=wan2.7-i2v
I2V_TEST_EDIT_MODEL=wan2.7-videoedit
I2V_TEST_RESOLUTION=720P
I2V_TEST_DURATION=5

# Optional providers. Fill only if enabled in config.yaml or worker templates.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
KIMI_API_KEY=

# Optional legacy/diagnostic Streamlit entrypoint. The React UI is the primary
# production UI.
MEMOX_STREAMLIT_USERNAME=admin
MEMOX_STREAMLIT_PASSWORD=
